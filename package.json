{
  "name": "ez-meeting",
  "version": "0.1.0",
  "private": true,
  "description": "Video meeting MVP — Express + Socket.io (see Scope.md)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:all": "bash start.sh",
    "dev": "node server.js",
    "build:handsigns": "esbuild scripts/handsigns-entry.js --bundle --format=iife --global-name=HandSignAlphabetKit --outfile=public/vendor/handsigns-alphabet.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "fingerpose": "^0.1.0",
    "franc": "^6.2.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "officeparser": "^6.0.4",
    "pdf-parse": "1.1.1",
    "qrcode": "^1.5.4",
    "simple-peer": "^9.11.1",
    "socket.io": "^4.8.1",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}

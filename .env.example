# Copy to .env and adjust. Server loads .env automatically via dotenv (see server.js).
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# better-auth (authentication)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# Shared meeting documents (summarize + per-user translation)
# Required for AI summaries — use a token with "Make calls to Inference Providers"
# https://huggingface.co/settings/tokens
HF_API_KEY=

# Optional override (default: https://router.huggingface.co/hf-inference/models)
# HF_INFERENCE_URL=https://router.huggingface.co/hf-inference/models

# Optional: FLAN-T5 model for key-ideas + study-question passes (default: google/flan-t5-base)
# HF_FLAN_MODEL=google/flan-t5-base

# Public LibreTranslate or your self-hosted instance
LIBRETRANSLATE_URL=https://libretranslate.com
# Optional if your LibreTranslate instance requires it
LIBRETRANSLATE_API_KEY=

# Upload limits
MAX_DOCUMENT_BYTES=20971520
MAX_EXTRACT_CHARS=80000
DOC_UPLOAD_COOLDOWN_MS=8000
UPLOAD_DIR=uploads

# Optional: path to LibreOffice soffice for legacy .ppt text extraction (otherwise heuristic only)
# macOS example: /Applications/LibreOffice.app/Contents/MacOS/soffice
# LIBREOFFICE_PATH=

# Whisper speech-to-text (server-side)
# Model size: tiny, base, small, medium, large (default: base)
WHISPER_MODEL=base
# Internal URL for the Python Whisper service (default: http://127.0.0.1:5555)
# WHISPER_URL=http://127.0.0.1:5555
# Port the Python Whisper service listens on (default: 5555)
# WHISPER_PORT=5555

# Supabase — meeting history persistence
# Create a project at https://supabase.com, then run the migration in supabase-migration.sql
SUPABASE_URL=
SUPABASE_ANON_KEY=

# DeepSeek — "Ask about this file" in the document sidebar (Q&A on extracted text)
# Get a key: https://platform.deepseek.com/api_keys — never commit real keys; use .env only.
DEEPSEEK_API_KEY=
# Additional DeepSeek keys for rate-limit rotation (auto-shuffles when one hits 429)
# DEEPSEEK_API_KEY_2=
# DEEPSEEK_API_KEY_3=
# Model id (default: deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat
# Cap how much extracted text is sent to DeepSeek (default 120000 chars)
# MAX_DEEPSEEK_CONTEXT_CHARS=120000
# Min ms between chat requests per user (default 5000)
# DOC_CHAT_COOLDOWN_MS=5000
